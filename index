<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Adventskalender</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Karla:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --nacht: #0a1428;
    --nacht-tief: #060d1c;
    --panel: #1c2a45;
    --panel-rand: #3a4a6a;
    --gold: #c89248;
    --gold-hell: #f4d484;
    --glut: #f4c870;
    --cream: #f4ead0;
    --cream-tief: #d8c89a;
    --tinte: #2a1a0a;
    --tinte-mittel: #4a3820;
    --tinte-hell: #8a6840;
    --himmel-text: #a8b8d5;
    --serif: "Fraunces", Georgia, serif;
    --sans: "Karla", -apple-system, system-ui, sans-serif;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--nacht); font-family: var(--sans); }

  .ak-wrap { background: linear-gradient(180deg, var(--nacht-tief) 0%, var(--nacht) 32%, var(--nacht) 100%); padding: 84px 26px 20px; position: relative; overflow: hidden; min-height: 780px; color: var(--cream); }

  /* ---------- Hintergrund ---------- */
  .ak-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .ak-bg svg { width: 100%; height: 100%; display: block; }
  .star { animation: ak-twinkle ease-in-out infinite; }
  @keyframes ak-twinkle { 0%, 100% { opacity: 0.25; } 50% { opacity: 1; } }
  .moon-glow { animation: ak-moonglow 7s ease-in-out infinite; }
  @keyframes ak-moonglow { 0%, 100% { opacity: 0.16; } 50% { opacity: 0.26; } }
  .window-lit { animation: ak-breathe ease-in-out infinite; }
  @keyframes ak-breathe { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }
  .bulb { animation: ak-blink ease-in-out infinite; }
  @keyframes ak-blink { 0%, 100% { opacity: 0.35; } 50% { opacity: 1; } }
  .walker-walk { animation: ak-walk 62s linear infinite; pointer-events: auto; cursor: pointer; }
  .walker-bob { animation: ak-bob 0.55s ease-in-out infinite; }
  @keyframes ak-walk { 0% { transform: translateX(-70px); } 100% { transform: translateX(1070px); } }
  @keyframes ak-bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-1.5px); } }
  .walker2-walk { animation: ak-walk2 74s linear infinite; }
  @keyframes ak-walk2 { 0% { transform: translateX(1070px) scaleX(-1); } 100% { transform: translateX(-70px) scaleX(-1); } }
  .lantern-glow { animation: ak-lantern 3s ease-in-out infinite; }
  @keyframes ak-lantern { 0%, 100% { opacity: 0.8; } 50% { opacity: 1; } }

  /* Sternschnuppe */
  .sternschnuppe { animation: ak-schnuppe 1.6s ease-in forwards; }
  @keyframes ak-schnuppe {
    0% { opacity: 0; transform: translate(0, 0); }
    12% { opacity: 1; }
    100% { opacity: 0; transform: translate(280px, 150px); }
  }

  /* Sprechblase des Wanderers */
  .ak-blase { position: absolute; z-index: 7; background: var(--cream); color: var(--tinte); font-family: var(--serif); font-style: italic; font-size: 13.5px; line-height: 1.45; padding: 10px 14px; border-radius: 10px; max-width: 240px; box-shadow: 0 6px 24px rgba(0,0,0,0.4); opacity: 0; transform: translateY(6px); transition: opacity 0.3s ease, transform 0.3s ease; pointer-events: none; }
  .ak-blase.show { opacity: 1; transform: translateY(0); }
  .ak-blase::after { content: ""; position: absolute; bottom: -7px; left: 22px; border: 7px solid transparent; border-top-color: var(--cream); border-bottom: none; }

  /* Schnee */
  .ak-snow { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
  .ak-snow-hinten { z-index: 1; }
  .ak-snow-vorne { z-index: 6; }
  .ak-snow span { position: absolute; top: -14px; background: rgba(255,255,255,0.6); border-radius: 50%; animation: ak-fall linear infinite; }
  .ak-snow-vorne span { filter: blur(2px); opacity: 0.5; }
  @keyframes ak-fall { to { transform: translateY(820px); } }

  /* ---------- Kopf ---------- */
  .ak-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 22px; position: relative; z-index: 3; gap: 12px; flex-wrap: wrap; }
  .ak-title { font-family: var(--serif); font-size: 26px; font-weight: 500; letter-spacing: 0.01em; color: var(--cream); margin: 0; }
  .ak-title em { font-style: italic; color: var(--gold-hell); }
  .ak-meta { font-size: 13px; color: var(--himmel-text); letter-spacing: 0.04em; }

  /* ---------- Grid + Türchen ---------- */
  .ak-grid { display: grid; grid-template-columns: repeat(6, 1fr); grid-auto-rows: 82px; gap: 8px; position: relative; z-index: 3; grid-auto-flow: dense; }
  .ak-door { position: relative; perspective: 800px; cursor: pointer; border: none; background: none; padding: 0; font: inherit; color: inherit; text-align: inherit; opacity: 0; transform: translateY(10px); }
  .ak-door.eingehaengt { animation: ak-einhaengen 0.5s cubic-bezier(0.2, 0.7, 0.3, 1) forwards; }
  @keyframes ak-einhaengen { to { opacity: 1; transform: translateY(0); } }
  .ak-door.tall { grid-row: span 2; }
  .ak-door.wide { grid-column: span 2; }
  .ak-door.finale { grid-column: span 2; grid-row: span 2; }
  .ak-door:focus-visible { outline: 2px solid var(--gold-hell); outline-offset: 3px; border-radius: 8px; }

  .door-licht { position: absolute; inset: -12px; border-radius: 14px; background: radial-gradient(ellipse at 30% 50%, rgba(244, 200, 112, 0.55), rgba(244, 200, 112, 0) 68%); opacity: 0; transition: opacity 1.1s ease 0.15s; pointer-events: none; z-index: 0; }
  .ak-door.opened .door-licht { opacity: 1; }

  .door-back { position: absolute; inset: 0; background: linear-gradient(160deg, #101f38 0%, #0c1828 100%); border: 1px solid #1e3050; border-radius: 7px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 6px; overflow: hidden; z-index: 1; }
  .door-thumb { width: 100%; flex: 1; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: var(--cream); font-size: 10px; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; padding: 4px; text-align: center; line-height: 1.3; overflow: hidden; }
  .door-thumb img { width: 100%; height: 100%; object-fit: cover; border-radius: 4px; display: block; }
  .door-back-num { font-family: var(--serif); font-size: 11px; color: var(--himmel-text); margin-top: 5px; }

  .door-front { position: absolute; inset: 0; border-radius: 7px; display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-size: 26px; font-weight: 500; font-variant-numeric: oldstyle-nums; transition: transform 0.85s cubic-bezier(0.55, -0.12, 0.25, 1.12); transform-origin: left center; backface-visibility: hidden; z-index: 2; overflow: hidden;
    background: linear-gradient(115deg, #223252 0%, #1c2a45 42%, #182540 100%);
    border: 1px solid var(--panel-rand);
    box-shadow: inset 1.5px 1.5px 0 rgba(240, 232, 213, 0.06), inset -1.5px -2px 0 rgba(0, 0, 0, 0.35), 0 2px 6px rgba(0, 0, 0, 0.3);
    color: #7a8aac;
  }
  .door-front::before { content: ""; position: absolute; left: 3px; top: 14%; bottom: 14%; width: 2px; border-radius: 1px; background: linear-gradient(180deg, transparent, rgba(240, 232, 213, 0.14) 18%, rgba(240, 232, 213, 0.14) 82%, transparent); }
  .door-front .decal { position: absolute; inset: 15%; width: 70%; height: 70%; opacity: 0.2; pointer-events: none; }
  .door-front .door-num { position: relative; z-index: 1; text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4); }
  .door-lock { position: absolute; bottom: 6px; right: 7px; width: 9px; height: 8px; border: 1.5px solid #4a5a7a; border-radius: 2px; z-index: 1; }
  .door-lock::before { content: ""; position: absolute; left: 1px; top: -5px; width: 4px; height: 5px; border: 1.5px solid #4a5a7a; border-bottom: none; border-radius: 3px 3px 0 0; }

  .ak-door.unlockable .door-front { background: linear-gradient(115deg, #5a4526 0%, #4a3820 45%, #3e2f1a 100%); border-color: #8a6840; color: var(--gold-hell); box-shadow: inset 1.5px 1.5px 0 rgba(244, 212, 132, 0.12), inset -1.5px -2px 0 rgba(0, 0, 0, 0.4), 0 2px 6px rgba(0, 0, 0, 0.3); }
  .ak-door.today .door-front { background: linear-gradient(115deg, #dba458 0%, #c89248 48%, #b58038 100%); border-color: var(--gold-hell); color: var(--tinte); animation: ak-pulse 2.8s ease-in-out infinite; box-shadow: inset 1.5px 1.5px 0 rgba(255, 232, 180, 0.4), inset -1.5px -2px 0 rgba(90, 60, 20, 0.4), 0 0 18px rgba(200, 146, 72, 0.35); }
  .ak-door.today .door-front .decal { opacity: 0.3; }
  @keyframes ak-pulse { 50% { box-shadow: inset 1.5px 1.5px 0 rgba(255, 232, 180, 0.4), inset -1.5px -2px 0 rgba(90, 60, 20, 0.4), 0 0 30px rgba(224, 170, 90, 0.55); } }

  /* Finale-Türchen 24 */
  .ak-door.finale .door-front { font-size: 40px; border-width: 2px; }
  .ak-door.finale .door-front .decal { opacity: 0.28; }
  .ak-door.finale.locked .door-front { border-color: #5a6a8a; color: #8a9abc; background: linear-gradient(115deg, #263758 0%, #1e2c4a 45%, #1a2842 100%); }

  @media (hover: hover) {
    .ak-door.unlockable:hover .door-front, .ak-door.today:hover .door-front { transform: rotateY(-12deg); }
    .ak-door.locked:hover .door-front { transform: rotateY(-2.5deg); }
    .ak-door.opened:hover .door-front { transform: rotateY(-146deg); }
  }
  .ak-door.opened .door-front { transform: rotateY(-140deg); animation: none; }
  .ak-door.shake .door-front { animation: ak-shake 0.5s ease; }
  @keyframes ak-shake { 0%,100% { transform: rotateY(0); } 20%,60% { transform: rotateY(-7deg); } 40%,80% { transform: rotateY(6deg); } }

  .ak-funke { position: absolute; width: 5px; height: 5px; border-radius: 50%; background: var(--glut); pointer-events: none; z-index: 8; animation: ak-funkeln 0.9s cubic-bezier(0.2, 0.6, 0.4, 1) forwards; box-shadow: 0 0 6px rgba(244, 200, 112, 0.8); }
  @keyframes ak-funkeln {
    0% { opacity: 1; transform: translate(0, 0) scale(1); }
    100% { opacity: 0; transform: translate(var(--fx), var(--fy)) scale(0.2); }
  }

  /* ---------- Fusszeile ---------- */
  .ak-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 22px; padding-top: 16px; border-top: 1px solid #1a2a45; position: relative; z-index: 3; font-size: 12px; color: var(--himmel-text); gap: 14px; flex-wrap: wrap; }
  .ak-progress { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .ak-kerzen { display: flex; gap: 3px; }
  .ak-kerze { width: 6px; height: 6px; border-radius: 50%; background: #1e3050; transition: background 0.4s ease, box-shadow 0.4s ease; }
  .ak-kerze.an { background: var(--glut); box-shadow: 0 0 5px rgba(244, 200, 112, 0.7); }
  .ak-streak { display: inline-flex; align-items: center; gap: 5px; color: var(--himmel-text); }
  .ak-streak svg { width: 11px; height: 14px; }
  .ak-controls button { background: transparent; border: 1px solid var(--panel-rand); color: var(--himmel-text); padding: 6px 14px; border-radius: 5px; font-size: 11.5px; cursor: pointer; font-family: var(--sans); font-weight: 500; letter-spacing: 0.03em; transition: background 0.15s ease, color 0.15s ease; }
  .ak-controls button:hover { background: #1a2a45; color: var(--cream); }
  .ak-controls button:focus-visible { outline: 2px solid var(--gold-hell); outline-offset: 2px; }
  .ak-controls button.active { background: #2a3a5a; color: var(--cream); border-color: #5a6a8a; }

  /* ---------- Modal ---------- */
  .ak-modal { position: fixed; inset: 0; background: rgba(4, 10, 22, 0.86); backdrop-filter: blur(3px); display: flex; align-items: center; justify-content: center; z-index: 1000; visibility: hidden; opacity: 0; transition: opacity 0.3s ease, visibility 0.3s ease; padding: 20px; cursor: pointer; }
  .ak-modal.show { visibility: visible; opacity: 1; }
  .ak-modal-card { background: linear-gradient(170deg, #f8f0da 0%, var(--cream) 55%, #eee0bc 100%); border-radius: 14px; padding: 28px; max-width: 480px; width: 100%; color: var(--tinte); position: relative; cursor: default; max-height: 90vh; overflow-y: auto; box-shadow: 0 24px 80px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(244, 212, 132, 0.18); transform: translateY(26px) scale(0.96); transition: transform 0.42s cubic-bezier(0.2, 0.9, 0.3, 1.08); }
  .ak-modal.show .ak-modal-card { transform: translateY(0) scale(1); }
  .ak-modal-x { position: absolute; top: 14px; right: 14px; background: transparent; border: none; color: var(--tinte-hell); cursor: pointer; padding: 6px 11px; font-size: 20px; line-height: 1; border-radius: 5px; font-family: var(--sans); }
  .ak-modal-x:hover { background: #e8d8a8; color: var(--tinte); }
  .ak-modal-x:focus-visible { outline: 2px solid var(--tinte-hell); }
  .ak-modal-day { font-family: var(--sans); font-size: 11.5px; color: var(--tinte-hell); font-weight: 600; margin: 0 0 6px; letter-spacing: 0.14em; padding-right: 44px; text-transform: uppercase; }
  .ak-modal-title { font-family: var(--serif); font-size: 25px; font-weight: 500; margin: 0 0 18px; color: var(--tinte); padding-right: 44px; line-height: 1.25; }
  .ak-modal-image-rahmen { border: 1px solid var(--cream-tief); border-radius: 8px; padding: 5px; background: #fff8ea; margin-bottom: 16px; }
  .ak-modal-image { width: 100%; border-radius: 5px; display: block; max-height: 320px; object-fit: cover; }
  .ak-modal-text { font-size: 14.5px; line-height: 1.65; color: var(--tinte-mittel); margin: 0 0 16px; white-space: pre-wrap; }
  .ak-modal-link { display: inline-block; color: var(--tinte-hell); text-decoration: underline; text-underline-offset: 3px; font-size: 13.5px; font-weight: 500; margin-bottom: 16px; }
  .ak-modal-link:hover { color: var(--tinte); }
  .ak-modal-credit { font-family: var(--serif); font-style: italic; font-size: 13.5px; color: var(--tinte-hell); margin: 0 0 8px; }
  .ak-modal-teaser { font-size: 12.5px; color: var(--tinte-hell); margin: 0 0 18px; padding: 8px 12px; background: rgba(216, 200, 154, 0.28); border-radius: 6px; }
  .ak-modal-belohnung { margin: 0 0 18px; padding: 14px 16px; background: linear-gradient(135deg, rgba(244, 212, 132, 0.4), rgba(200, 146, 72, 0.22)); border: 1px solid var(--gold); border-radius: 8px; }
  .ak-modal-belohnung h3 { font-family: var(--serif); font-size: 15px; font-weight: 600; margin: 0 0 6px; color: var(--tinte); }
  .ak-modal-belohnung p { font-size: 13.5px; line-height: 1.55; color: var(--tinte-mittel); margin: 0; }
  .ak-modal-belohnung a { color: var(--tinte); font-weight: 600; }
  .ak-modal-nav { display: flex; justify-content: space-between; align-items: center; gap: 10px; border-top: 1px solid var(--cream-tief); padding-top: 16px; }
  .ak-modal-nav button { background: transparent; border: 1px solid var(--cream-tief); color: var(--tinte-mittel); padding: 8px 14px; border-radius: 5px; font-size: 13px; font-weight: 500; cursor: pointer; font-family: var(--sans); transition: background 0.15s ease; }
  .ak-modal-nav button:hover:not(:disabled) { background: #ecdcb2; }
  .ak-modal-nav button:disabled { opacity: 0.35; cursor: default; }
  .ak-modal-nav button:focus-visible { outline: 2px solid var(--tinte-hell); }
  .ak-modal-close { background: var(--tinte) !important; color: var(--cream) !important; border-color: var(--tinte) !important; }
  .ak-modal-close:hover { background: var(--tinte-mittel) !important; }
  .ak-pw-input { width: 100%; padding: 11px 14px; border: 1px solid var(--cream-tief); border-radius: 6px; background: #fff8ea; color: var(--tinte); font-family: var(--sans); font-size: 14.5px; margin-bottom: 8px; }
  .ak-pw-input:focus { outline: 2px solid var(--gold); border-color: var(--gold); }
  .ak-pw-fehler { display: none; font-size: 13px; color: #b04a30; margin: 0 0 12px; }
  .ak-pw-fehler.zeig { display: block; }
  .ak-pw-wartet { opacity: 0.6; pointer-events: none; }

  /* ---------- Toast / Laden / Fehler ---------- */
  .ak-toast { position: fixed; bottom: 32px; left: 50%; transform: translateX(-50%) translateY(20px); background: #1a2a45; color: var(--cream); padding: 11px 20px; border-radius: 7px; font-size: 13px; opacity: 0; transition: all 0.3s ease; z-index: 999; border: 1px solid var(--panel-rand); pointer-events: none; box-shadow: 0 8px 26px rgba(0, 0, 0, 0.4); }
  .ak-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  .ak-loading, .ak-error { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; z-index: 5; background: var(--nacht); font-size: 14px; padding: 24px; text-align: center; }
  .ak-loading { color: var(--himmel-text); }
  .ak-error { color: #e8849a; }
  .ak-loading.hidden, .ak-error.hidden { display: none; }

  /* ---------- Mobile ---------- */
  @media (max-width: 520px) {
    .ak-wrap { padding: 64px 14px 16px; }
    .ak-grid { grid-template-columns: repeat(4, 1fr); grid-auto-rows: 84px; }
    .ak-title { font-size: 21px; }
    .door-front { font-size: 23px; }
    .ak-door.finale .door-front { font-size: 34px; }
    .ak-kerzen { display: none; }
  }

  /* ---------- Reduzierte Bewegung ---------- */
  @media (prefers-reduced-motion: reduce) {
    .star, .window-lit, .bulb, .moon-glow, .lantern-glow, .ak-door.today .door-front { animation: none; }
    .walker-walk, .walker2-walk, .walker-bob { animation: none; }
    .ak-snow span { animation: none; display: none; }
    .sternschnuppe { display: none; }
    .ak-door { opacity: 1; transform: none; }
    .ak-door.eingehaengt { animation: none; }
    .door-front { transition-duration: 0.2s; }
    .ak-modal-card { transition: none; transform: none; }
    .ak-funke { display: none; }
  }
</style>
</head>
<body>
<div class="ak-wrap">
  <div class="ak-bg">
    <svg viewBox="0 0 1000 780" preserveAspectRatio="xMidYMax slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <g id="stars"></g>
      <g id="schnuppen"></g>
      <g id="moon">
        <circle cx="500" cy="46" r="94" fill="#e8d8a8" opacity="0.05" class="moon-glow"/>
        <circle cx="500" cy="46" r="70" fill="#e8d8a8" opacity="0.10" class="moon-glow"/>
        <circle cx="500" cy="46" r="52" fill="#e8d8a8" opacity="0.18"/>
        <circle cx="500" cy="46" r="37" fill="#f4e8c8"/>
        <circle id="moon-schatten" cx="514" cy="43" r="34" fill="#0a1428"/>
        <circle cx="481" cy="40" r="4" fill="#d8c89a" opacity="0.6"/>
        <circle cx="473" cy="54" r="3" fill="#d8c89a" opacity="0.55"/>
        <circle cx="486" cy="62" r="2.2" fill="#d8c89a" opacity="0.5"/>
      </g>
      <path d="M0 595 L120 535 L220 575 L340 515 L460 565 L580 525 L700 575 L820 535 L920 565 L1000 545 L1000 780 L0 780 Z" fill="#0d1830"/>
      <path d="M0 640 L100 600 L200 630 L320 590 L440 625 L560 600 L680 635 L800 600 L900 630 L1000 615 L1000 780 L0 780 Z" fill="#0a1428"/>
      <g id="houses"></g>
      <g id="lights"></g>
      <rect x="0" y="745" width="1000" height="35" fill="#1a2438"/>
      <g class="walker-walk" id="walker" role="button" tabindex="-1">
        <g class="walker-bob">
          <g transform="translate(0, 726)">
            <rect x="-6" y="-14" width="52" height="42" fill="transparent"/>
            <circle cx="35" cy="7" r="13" fill="#f4c870" opacity="0.18"/>
            <circle cx="35" cy="7" r="8" fill="#f4c870" opacity="0.35" class="lantern-glow"/>
            <rect x="32" y="5" width="6" height="6" fill="#2a1a0a"/>
            <rect x="33" y="6" width="4" height="4" fill="#f4c870" class="lantern-glow"/>
            <line x1="35" y1="5" x2="35" y2="0" stroke="#2a1a0a" stroke-width="1"/>
            <circle cx="5" cy="-2" r="4" fill="#0a0a0a"/>
            <rect x="2" y="2" width="6" height="13" fill="#0a0a0a"/>
            <line x1="8" y1="6" x2="33" y2="4" stroke="#0a0a0a" stroke-width="1.5"/>
            <rect x="2.5" y="15" width="2" height="6" fill="#0a0a0a"/>
            <rect x="5.5" y="15" width="2" height="6" fill="#0a0a0a"/>
          </g>
        </g>
      </g>
      <g class="walker2-walk" id="walker2" style="display:none">
        <g class="walker-bob">
          <g transform="translate(0, 726)">
            <circle cx="5" cy="-2" r="4" fill="#0a0a0a"/>
            <rect x="2" y="2" width="6" height="13" fill="#0a0a0a"/>
            <rect x="1" y="3" width="8" height="3" fill="#c85a5a"/>
            <rect x="2.5" y="15" width="2" height="6" fill="#0a0a0a"/>
            <rect x="5.5" y="15" width="2" height="6" fill="#0a0a0a"/>
          </g>
        </g>
      </g>
    </svg>
  </div>
  <div class="ak-snow ak-snow-hinten" id="ak-snow-hinten" aria-hidden="true"></div>
  <div class="ak-header">
    <h1 class="ak-title" id="ak-title">Adventskalender</h1>
    <span class="ak-meta" id="ak-meta">Lädt …</span>
  </div>
  <div class="ak-grid" id="ak-grid" role="list"></div>
  <div class="ak-footer">
    <div class="ak-progress">
      <span id="ak-count">0 von 24 geöffnet</span>
      <div class="ak-kerzen" id="ak-kerzen" aria-hidden="true"></div>
