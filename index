    { x: 925, w: 60, h: 100, roof: 'peak' }
  ];
  const dunkleFenster = [];
  let geheimFensterGesetzt = false;
  houseDefs.forEach((h, hausIdx) => {
    const yBase = 745, yTop = yBase - h.h;
    const body = document.createElementNS(SVG_NS, 'rect');
    body.setAttribute('x', h.x); body.setAttribute('y', yTop);
    body.setAttribute('width', h.w); body.setAttribute('height', h.h);
    body.setAttribute('fill', '#0a1220');
    houses.appendChild(body);
    if (h.roof === 'peak') {
      const r = document.createElementNS(SVG_NS, 'polygon');
      r.setAttribute('points', `${h.x - 4},${yTop} ${h.x + h.w/2},${yTop - 30} ${h.x + h.w + 4},${yTop}`);
      r.setAttribute('fill', '#080f1c');
      houses.appendChild(r);
      const snowCap = document.createElementNS(SVG_NS, 'polygon');
      snowCap.setAttribute('points', `${h.x + h.w/2 - 18},${yTop - 8} ${h.x + h.w/2},${yTop - 30} ${h.x + h.w/2 + 18},${yTop - 8}`);
      snowCap.setAttribute('fill', '#e8eef8'); snowCap.setAttribute('opacity', '0.18');
      houses.appendChild(snowCap);
    } else {
      const snowTop = document.createElementNS(SVG_NS, 'rect');
      snowTop.setAttribute('x', h.x - 2); snowTop.setAttribute('y', yTop - 6);
      snowTop.setAttribute('width', h.w + 4); snowTop.setAttribute('height', 7);
      snowTop.setAttribute('fill', '#e8eef8'); snowTop.setAttribute('opacity', '0.2');
      houses.appendChild(snowTop);
    }
    const winCols = Math.max(1, Math.floor(h.w / 22));
    const winRows = Math.max(1, Math.floor(h.h / 30));
    for (let row = 0; row < winRows; row++) {
      for (let col = 0; col < winCols; col++) {
        const wx = h.x + 8 + col * 20;
        const wy = yTop + 14 + row * 28;
        if (wx + 10 > h.x + h.w - 4) continue;
        const istGeheim = !geheimFensterGesetzt && hausIdx === 7 && row === 1 && col === 1;
        const lit = istGeheim ? true : Math.random() > 0.42;
        const w = document.createElementNS(SVG_NS, 'rect');
        w.setAttribute('x', wx); w.setAttribute('y', wy);
        w.setAttribute('width', 10); w.setAttribute('height', 14);
        w.setAttribute('fill', istGeheim ? '#ff9a5a' : (lit ? '#f4c870' : '#1a2438'));
        if (istGeheim) {
          geheimFensterGesetzt = true;
          w.setAttribute('class', 'window-lit');
          w.style.animationDuration = '5s';
          w.style.pointerEvents = 'auto';
          w.style.cursor = 'pointer';
          w.addEventListener('click', () => { if (typeof oeffnePwModal === 'function') oeffnePwModal(); });
          // Grosszügige unsichtbare Klickfläche darüber
          const hit = document.createElementNS(SVG_NS, 'rect');
          hit.setAttribute('x', wx - 8); hit.setAttribute('y', wy - 8);
          hit.setAttribute('width', 26); hit.setAttribute('height', 30);
          hit.setAttribute('fill', 'transparent');
          hit.style.pointerEvents = 'auto';
          hit.style.cursor = 'pointer';
          hit.addEventListener('click', () => { if (typeof oeffnePwModal === 'function') oeffnePwModal(); });
          houses.appendChild(hit);
        } else if (lit) {
          w.setAttribute('class', 'window-lit');
          w.style.animationDuration = (3 + Math.random() * 4) + 's';
          w.style.animationDelay = (Math.random() * 4) + 's';
        } else {
          dunkleFenster.push(w);
        }
        houses.appendChild(w);
      }
    }
  });
  const lights = document.getElementById('lights');
  const stringPath = document.createElementNS(SVG_NS, 'path');
  stringPath.setAttribute('d', 'M 0 480 Q 250 540, 500 500 T 1000 510');
  stringPath.setAttribute('stroke', '#3a4a6a'); stringPath.setAttribute('stroke-width', '1');
  stringPath.setAttribute('fill', 'none'); stringPath.setAttribute('opacity', '0.5');
  lights.appendChild(stringPath);
  const bulbColors = ['#f4c870', '#e8849a', '#84d4e8', '#a8d484', '#f49a6a'];
  for (let i = 0; i < 22; i++) {
    const t = i / 21;
    const cx = t * 1000;
    let cy;
    if (t < 0.5) { const lt = t * 2; cy = 480 + 60 * (lt * (1 - lt) * 4) - 5 * lt; }
    else { const lt = (t - 0.5) * 2; cy = 500 + 10 * lt + Math.sin(lt * Math.PI) * 8; }
    const b = document.createElementNS(SVG_NS, 'circle');
    b.setAttribute('cx', cx); b.setAttribute('cy', cy); b.setAttribute('r', 2.5);
    b.setAttribute('fill', bulbColors[i % bulbColors.length]);
    b.setAttribute('class', 'bulb');
    b.style.animationDuration = (1.8 + Math.random() * 2) + 's';
    b.style.animationDelay = (Math.random() * 3) + 's';
    lights.appendChild(b);
  }
  function baueSchnee(el, anzahl, vorne) {
    for (let i = 0; i < anzahl; i++) {
      const s = document.createElement('span');
      const size = vorne ? 5 + Math.random() * 3 : 2 + Math.random() * 2.5;
      s.style.width = size + 'px'; s.style.height = size + 'px';
      s.style.left = Math.random() * 100 + '%';
      s.style.animationDuration = (vorne ? 6 : 4.5) + Math.random() * (vorne ? 4 : 5) + 's';
      s.style.animationDelay = (Math.random() * 8) + 's';
      if (!vorne) s.style.opacity = 0.3 + Math.random() * 0.45;
      el.appendChild(s);
    }
  }
  baueSchnee(document.getElementById('ak-snow-hinten'), 50, false);
  baueSchnee(document.getElementById('ak-snow-vorne'), 14, true);

  // --- Mondphase: Schattenkreis wandert über die 24 Tage weg (Tag 1 schmale Sichel → Tag 24 Vollmond) ---
  function setzeMondphase(today) {
    const t = Math.max(1, Math.min(24, today || 1));
    const offset = 14 + ((t - 1) / 23) * 68; // 14 (schmal) → 82 (weg = Vollmond)
    document.getElementById('moon-schatten').setAttribute('cx', 500 + offset);
  }

  // --- Sternschnuppen (ab 20.12. gelegentlich, im Finale als Burst) ---
  function spawnSternschnuppe() {
    if (reducedMotion) return;
    const g = document.getElementById('schnuppen');
    const startX = 60 + Math.random() * 700;
    const startY = 10 + Math.random() * 120;
    const grp = document.createElementNS(SVG_NS, 'g');
    grp.setAttribute('class', 'sternschnuppe');
    grp.setAttribute('transform-origin', `${startX} ${startY}`);
    const linie = document.createElementNS(SVG_NS, 'line');
    linie.setAttribute('x1', startX - 34); linie.setAttribute('y1', startY - 18);
    linie.setAttribute('x2', startX); linie.setAttribute('y2', startY);
    linie.setAttribute('stroke', '#f4ead0'); linie.setAttribute('stroke-width', '1.4');
    linie.setAttribute('stroke-linecap', 'round'); linie.setAttribute('opacity', '0.75');
    const kopf = document.createElementNS(SVG_NS, 'circle');
    kopf.setAttribute('cx', startX); kopf.setAttribute('cy', startY);
    kopf.setAttribute('r', '2'); kopf.setAttribute('fill', '#f4e8c8');
    grp.appendChild(linie); grp.appendChild(kopf);
    g.appendChild(grp);
    setTimeout(() => grp.remove(), 1700);
  }
  function starteSchnuppenSaison() {
    function next() {
      spawnSternschnuppe();
      setTimeout(next, 16000 + Math.random() * 22000);
    }
    setTimeout(next, 5000 + Math.random() * 10000);
  }

  // --- Finale-Himmel (Türchen 24): alle Fenster an + Schnuppen-Burst + Mond-Aufleuchten ---
  function finaleHimmel() {
    dunkleFenster.forEach((w, i) => {
      setTimeout(() => {
        w.setAttribute('fill', '#f4c870');
        w.setAttribute('class', 'window-lit');
        w.style.animationDuration = (3 + Math.random() * 4) + 's';
      }, 60 * i + Math.random() * 300);
    });
    if (!reducedMotion) {
      for (let i = 0; i < 6; i++) setTimeout(spawnSternschnuppe, 400 + i * 550);
    }
  }

  // --- Decals ---
  const decals = [
    `<svg class="decal" viewBox="0 0 100 100" aria-hidden="true"><g stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"><line x1="50" y1="12" x2="50" y2="88"/><line x1="17" y1="31" x2="83" y2="69"/><line x1="83" y1="31" x2="17" y2="69"/><path d="M 50 22 L 44 28 M 50 22 L 56 28 M 50 78 L 44 72 M 50 78 L 56 72"/><path d="M 26 36 L 30 30 M 26 36 L 22 30 M 74 64 L 70 70 M 74 64 L 78 70"/><path d="M 74 36 L 78 30 M 74 36 L 70 30 M 26 64 L 22 70 M 26 64 L 30 70"/></g></svg>`,
    `<svg class="decal" viewBox="0 0 100 100" aria-hidden="true"><g stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round"><line x1="50" y1="12" x2="50" y2="88"/><line x1="50" y1="22" x2="28" y2="34"/><line x1="50" y1="22" x2="72" y2="34"/><line x1="50" y1="42" x2="22" y2="56"/><line x1="50" y1="42" x2="78" y2="56"/><line x1="50" y1="62" x2="18" y2="80"/><line x1="50" y1="62" x2="82" y2="80"/></g></svg>`,
    `<svg class="decal" viewBox="0 0 100 100" aria-hidden="true"><g stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round"><path d="M 50 50 Q 30 30 22 50 Q 30 70 50 50 Q 70 30 78 50 Q 70 70 50 50 Z"/><circle cx="50" cy="50" r="4"/><line x1="45" y1="55" x2="38" y2="80"/><line x1="55" y1="55" x2="62" y2="80"/></g></svg>`,
    `<svg class="decal" viewBox="0 0 100 100" aria-hidden="true"><polygon points="50,12 60,38 88,38 66,55 75,84 50,68 25,84 34,55 12,38 40,38" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linejoin="round"/></svg>`,
    `<svg class="decal" viewBox="0 0 100 100" aria-hidden="true"><g stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round"><rect x="38" y="38" width="24" height="46"/><line x1="50" y1="38" x2="50" y2="26"/><path d="M 44 26 Q 50 8 56 26 Q 52 18 50 24 Q 48 18 44 26 Z"/></g></svg>`,
    `<svg class="decal" viewBox="0 0 100 100" aria-hidden="true"><g stroke="currentColor" stroke-width="2.5" fill="none" stroke-linejoin="round"><rect x="18" y="38" width="64" height="48"/><line x1="18" y1="52" x2="82" y2="52"/><line x1="50" y1="38" x2="50" y2="86"/><path d="M 32 38 Q 38 18 50 30 Q 62 18 68 38"/></g></svg>`,
    `<svg class="decal" viewBox="0 0 100 100" aria-hidden="true"><g stroke="currentColor" stroke-width="2.5" fill="none" stroke-linejoin="round" stroke-linecap="round"><path d="M 35 22 L 35 58 Q 35 76 52 76 L 78 76 L 78 64 Q 78 58 72 58 L 62 58 L 62 22 Z"/><rect x="32" y="18" width="33" height="6"/></g></svg>`,
    `<svg class="decal" viewBox="0 0 100 100" aria-hidden="true"><g stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round"><line x1="50" y1="20" x2="50" y2="58"/><ellipse cx="36" cy="48" rx="14" ry="6" transform="rotate(-30 36 48)"/><ellipse cx="64" cy="48" rx="14" ry="6" transform="rotate(30 64 48)"/><circle cx="50" cy="66" r="3.5"/><circle cx="42" cy="74" r="3.5"/><circle cx="58" cy="74" r="3.5"/></g></svg>`
  ];
  const STERN_DECAL = 3;

  // --- Audio ---
  let audioCtx = null, soundOn = true;
  function ensureAudio() {
    if (!audioCtx) { try { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); } catch(e) { return null; } }
    if (audioCtx.state === 'suspended') audioCtx.resume();
    return audioCtx;
  }
  function playBell() {
    if (!soundOn) return; const ctx = ensureAudio(); if (!ctx) return;
    const now = ctx.currentTime;
    const filter = ctx.createBiquadFilter();
    filter.type = 'lowpass'; filter.frequency.value = 2400; filter.Q.value = 0.6;
    filter.connect(ctx.destination);
    [523.25, 659.25, 783.99].forEach((freq) => {
      const o = ctx.createOscillator(), g = ctx.createGain();
      o.type = 'sine'; o.frequency.value = freq;
      g.gain.setValueAtTime(0, now);
      g.gain.linearRampToValueAtTime(0.13, now + 0.015);
      g.gain.exponentialRampToValueAtTime(0.001, now + 1.8);
      o.connect(g).connect(filter);
      o.start(now); o.stop(now + 1.8);
      const o2 = ctx.createOscillator(), g2 = ctx.createGain();
      o2.type = 'sine'; o2.frequency.value = freq * 2;
      g2.gain.setValueAtTime(0, now);
      g2.gain.linearRampToValueAtTime(0.04, now + 0.02);
      g2.gain.exponentialRampToValueAtTime(0.001, now + 0.9);
      o2.connect(g2).connect(filter);
      o2.start(now); o2.stop(now + 0.9);
    });
  }
  // Finale: aufsteigendes Arpeggio + gehaltener Schlussakkord (eigene Tonfolge)
  function playFinale() {
    if (!soundOn) return; const ctx = ensureAudio(); if (!ctx) return;
    const now = ctx.currentTime;
    const filter = ctx.createBiquadFilter();
    filter.type = 'lowpass'; filter.frequency.value = 2600; filter.Q.value = 0.5;
    filter.connect(ctx.destination);
    const arp = [523.25, 659.25, 783.99, 1046.5];
    arp.forEach((freq, i) => {
      const t0 = now + i * 0.19;
      const o = ctx.createOscillator(), g = ctx.createGain();
      o.type = 'sine'; o.frequency.value = freq;
      g.gain.setValueAtTime(0, t0);
      g.gain.linearRampToValueAtTime(0.12, t0 + 0.02);
      g.gain.exponentialRampToValueAtTime(0.001, t0 + 1.2);
      o.connect(g).connect(filter);
      o.start(t0); o.stop(t0 + 1.2);
    });
    const akkordStart = now + 0.85;
    [523.25, 659.25, 783.99, 1046.5].forEach((freq) => {
      const o = ctx.createOscillator(), g = ctx.createGain();
      o.type = 'sine'; o.frequency.value = freq;
      g.gain.setValueAtTime(0, akkordStart);
      g.gain.linearRampToValueAtTime(0.09, akkordStart + 0.08);
      g.gain.setValueAtTime(0.09, akkordStart + 1.4);
      g.gain.exponentialRampToValueAtTime(0.001, akkordStart + 3.2);
      o.connect(g).connect(filter);
      o.start(akkordStart); o.stop(akkordStart + 3.2);
    });
  }
  function playLocked() {
    if (!soundOn) return; const ctx = ensureAudio(); if (!ctx) return;
    const now = ctx.currentTime;
    const bufferSize = ctx.sampleRate * 0.06;
    const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
    const data = buffer.getChannelData(0);
    for (let i = 0; i < bufferSize; i++) {
      data[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / bufferSize, 3);
    }
    const noise = ctx.createBufferSource();
    noise.buffer = buffer;
    const filter = ctx.createBiquadFilter();
    filter.type = 'lowpass'; filter.frequency.value = 420; filter.Q.value = 8;
    const g = ctx.createGain(); g.gain.value = 0.45;
    noise.connect(filter).connect(g).connect(ctx.destination);
    noise.start(now);
  }

  function shuffle(a) { for (let i = a.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [a[i], a[j]] = [a[j], a[i]]; } return a; }

  function funkenBurst(doorEl, anzahl) {
    if (reducedMotion) return;
    const n = anzahl || 8;
    const rect = doorEl.getBoundingClientRect();
    const wrap = document.querySelector('.ak-wrap');
    const wrapRect = wrap.getBoundingClientRect();
    const cx = rect.left - wrapRect.left + rect.width * 0.4;
    const cy = rect.top - wrapRect.top + rect.height * 0.5;
    for (let i = 0; i < n; i++) {
      const f = document.createElement('span');
      f.className = 'ak-funke';
      f.style.left = cx + 'px';
      f.style.top = cy + 'px';
      const winkel = (Math.PI * 2 * i) / n + Math.random() * 0.5;
      const dist = 34 + Math.random() * (n > 10 ? 60 : 30);
      f.style.setProperty('--fx', Math.cos(winkel) * dist + 'px');
      f.style.setProperty('--fy', (Math.sin(winkel) * dist - 22) + 'px');
      wrap.appendChild(f);
      setTimeout(() => f.remove(), 950);
    }
  }

  // --- Datum + Test-Modus ---
  function calcToday(jahr, testMode) {
    if (testMode === true || String(testMode).toUpperCase() === 'TRUE') return 24;
    const num = Number(testMode);
    if (!isNaN(num) && num >= 1 && num <= 24) return num;
    const now = new Date();
    const start = new Date(jahr, 11, 1);
    if (now < start) return 0;
    const dec25 = new Date(jahr, 11, 25);
    if (now >= dec25) return 24;
    return now.getDate();
  }
  function formatToday(today, jahr, testMode) {
    if (testMode === true || String(testMode).toUpperCase() === 'TRUE') return 'Test-Modus · alle Türchen offen';
    const num = Number(testMode);
    if (!isNaN(num) && num >= 1 && num <= 24) return `Test-Modus · simuliert ${num}. Dezember`;
    if (today === 0) {
      const now = new Date();
      const start = new Date(jahr, 11, 1);
      const tage = Math.ceil((start - now) / 86400000);
      return `Noch ${tage} ${tage === 1 ? 'Tag' : 'Tage'} bis zum 1. Dezember`;
    }
    if (today >= 24) return 'Alle Türchen geöffnet — frohe Weihnachten!';
    return `Heute: ${today}. Dezember`;
  }

  // --- Layout (persistent pro Jahr, Türchen 24 immer Finale) ---
  function getLayout(jahr) {
    const KEY = `adventskalender_${jahr}_layout`;
    let layout = null;
    const stored = localStorage.getItem(KEY);
    if (stored) { try { layout = JSON.parse(stored); } catch(e) {} }
    if (!layout) {
      const sizes = [...Array(4).fill('tall'), ...Array(2).fill('wide'), ...Array(18).fill('small')];
      shuffle(sizes);
      const numbers = shuffle(Array.from({length: 24}, (_, i) => i + 1));
      layout = numbers.map((n, i) => ({
        tag: n,
        size: sizes[i],
        decal: Math.random() > 0.5 ? Math.floor(Math.random() * decals.length) : -1
      }));
    }
    // Türchen 24 normalisieren: immer Finale-Grösse + Stern (auch für alte gespeicherte Layouts)
    const slot24 = layout.find(s => s.tag === 24);
    if (slot24) { slot24.size = 'finale'; slot24.decal = STERN_DECAL; }
    try { localStorage.setItem(KEY, JSON.stringify(layout)); } catch(e) {}
    return layout;
  }
  function getSet(key) {
    try { return new Set(JSON.parse(localStorage.getItem(key) || '[]')); } catch(e) { return new Set(); }
  }
  function saveSet(key, set) {
    try { localStorage.setItem(key, JSON.stringify([...set])); } catch(e) {}
  }

  // --- Türchen-Daten + Typ-Optik ---
  function getTuerData(tag, tueren) {
    const found = tueren.find(t => Number(t.tag) === tag);
    if (found) return found;
    return { tag: tag, titel: 'Noch geheim', text: 'Inhalt folgt — schau später wieder vorbei.', einreicher: '', typ: 'sonstiges', bild_url: '', link: '' };
  }
  const typFarben = { bild: '#3a5a7a', story: '#5a4830', build: '#3a5a4a', sonstiges: '#44445c' };
  function thumbFarbe(typ) { return typFarben[String(typ || '').toLowerCase()] || typFarben.sonstiges; }
  function thumbLabel(typ) {
    const t = String(typ || 'sonstiges').toLowerCase();
    if (t === 'bild') return 'Bild';
    if (t === 'story') return 'Story';
    if (t === 'build') return 'Build';
    return 'Beitrag';
  }

  // --- Globaler Zustand ---
  let doorElemente = {};
  let globalOpened = null, globalPuenktlich = null, globalJahr = null, globalConfig = {};
  let modalState = { tag: null, tueren: [], today: 0 };

  function navigierbareTage() {
    return Array.from({length: modalState.today}, (_, i) => i + 1);
  }
  function updateModalNav() {
    const tage = navigierbareTage();
    const idx = tage.indexOf(modalState.tag);
    document.getElementById('ak-modal-prev').disabled = idx <= 0;
    document.getElementById('ak-modal-next').disabled = idx < 0 || idx >= tage.length - 1;
  }

  function showModal(tag) {
    modalState.tag = tag;
    const daten = getTuerData(tag, modalState.tueren);
    document.getElementById('ak-modal-day').textContent = `${tag}. Dezember`;
    document.getElementById('ak-modal-title').textContent = daten.titel || `Türchen ${tag}`;
    const rahmen = document.getElementById('ak-modal-image-rahmen');
    const img = document.getElementById('ak-modal-image');
    if (daten.bild_url) { img.src = daten.bild_url; img.alt = daten.titel || ''; rahmen.style.display = 'block'; }
    else { rahmen.style.display = 'none'; img.removeAttribute('src'); }
    document.getElementById('ak-modal-text').textContent = daten.text || '';
    const link = document.getElementById('ak-modal-link');
    if (daten.link) {
      link.href = daten.link;
      link.target = /:\/\//.test(String(daten.link)) ? '_blank' : '_self';
      link.style.display = 'inline-block';
    }
    else { link.style.display = 'none'; }
    document.getElementById('ak-modal-credit').textContent = daten.einreicher ? `Eingereicht von ${daten.einreicher}` : '';

    // Streak-Belohnung: nur im Finale-Modal, nur bei voller Kerzenreihe
    const belohnung = document.getElementById('ak-modal-belohnung');
    if (tag === 24 && globalPuenktlich && globalPuenktlich.size >= 24) {
      document.getElementById('ak-belohnung-text').innerHTML = belohnungHtml();
      belohnung.style.display = 'block';
    } else {
      belohnung.style.display = 'none';
    }

    // Morgen-Teaser: nur beim heutigen Türchen, nur wenn morgen existiert + Einreicher bekannt
    const teaser = document.getElementById('ak-modal-teaser');
    const morgen = tag + 1;
    if (tag === modalState.today && morgen <= 24) {
      const morgenDaten = modalState.tueren.find(t => Number(t.tag) === morgen);
      if (morgenDaten && morgenDaten.einreicher) {
        teaser.textContent = `Morgen öffnet: ein Beitrag von ${morgenDaten.einreicher}.`;
        teaser.style.display = 'block';
      } else {
        teaser.style.display = 'none';
      }
    } else {
      teaser.style.display = 'none';
    }

    updateModalNav();
    const modal = document.getElementById('ak-modal');
    modal.classList.add('show');
    modal.setAttribute('aria-hidden', 'false');
    document.getElementById('ak-modal-close').focus();
  }
  function belohnungHtml() {
    const txt = globalConfig.streak_belohnung_text || 'Du hast alle 24 Türchen am jeweiligen Tag geöffnet — die volle Kerzenreihe. Danke, dass du jeden Tag dabei warst.';
    const link = globalConfig.streak_belohnung_link;
    const esc = String(txt).replace(/&/g, '&amp;').replace(/</g, '&lt;');
    return link ? `${esc} <a href="${String(link).replace(/"/g, '&quot;')}" target="_blank" rel="noopener">Zu deiner Belohnung →</a>` : esc;
  }
  function closeModal() {
    const modal = document.getElementById('ak-modal');
    modal.classList.remove('show');
    modal.setAttribute('aria-hidden', 'true');
  }
  function modalNav(richtung) {
    const tage = navigierbareTage();
    const idx = tage.indexOf(modalState.tag);
    const next = tage[idx + richtung];
    if (next) {
      oeffneTuerFallsNoetig(next);
      showModal(next);
    }
  }
  function showToast(msg) {
    const t = document.getElementById('ak-toast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(t._tid);
    t._tid = setTimeout(() => t.classList.remove('show'), 2000);
  }

  function oeffneTuerFallsNoetig(tag) {
    if (globalOpened && !globalOpened.has(tag)) {
      globalOpened.add(tag);
      saveSet(`adventskalender_${globalJahr}_opened`, globalOpened);
      registrierePuenktlich(tag);
      const el = doorElemente[tag];
      if (el) {
        el.classList.add('opened');
        const daten = getTuerData(tag, modalState.tueren);
        if (daten.bild_url) {
          el.querySelector('.door-thumb').innerHTML = `<img src="${daten.bild_url}" alt="" loading="lazy">`;
        }
      }
      updateProgress();
    }
  }
  function registrierePuenktlich(tag) {
    if (tag === modalState.today && globalPuenktlich && !globalPuenktlich.has(tag)) {
      globalPuenktlich.add(tag);
      saveSet(`adventskalender_${globalJahr}_puenktlich`, globalPuenktlich);
    }
  }

  function updateProgress() {
    if (!globalOpened) return;
    const n = [...globalOpened].filter(t => t <= modalState.today).length;
    document.getElementById('ak-count').textContent = `${n} von 24 geöffnet`;
    const kerzen = document.getElementById('ak-kerzen').children;
    for (let i = 0; i < kerzen.length; i++) {
      kerzen[i].classList.toggle('an', i < n);
    }
    document.getElementById('ak-streak-num').textContent = globalPuenktlich ? globalPuenktlich.size : 0;
  }

  // --- Wanderer: Klick → Spruch des Tages ---
  const fallbackSprueche = [
    'Kalte Füsse, warmes Licht.',
    'Der Schnee erzählt, wer unterwegs war.',
    'Noch ein Fenster, dann bin ich zuhause.',
    'Manche Türen öffnen sich nur einmal im Jahr.',
    'Die Laterne kennt den Weg.'
  ];
  let sprueche = {};
  function walkerKlick() {
    const walkerEl = document.getElementById('walker');
    const blase = document.getElementById('ak-blase');
    const wrapRect = document.querySelector('.ak-wrap').getBoundingClientRect();
    const rect = walkerEl.getBoundingClientRect();
    walkerEl.style.animationPlayState = 'paused';
    const spruch = sprueche[modalState.today] || fallbackSprueche[(modalState.today || 1) % fallbackSprueche.length];
    blase.textContent = spruch;
    blase.classList.add('show');
    blase.style.left = Math.max(8, Math.min(rect.left - wrapRect.left - 40, wrapRect.width - 260)) + 'px';
    blase.style.top = (rect.top - wrapRect.top - 74) + 'px';
    clearTimeout(blase._tid);
    blase._tid = setTimeout(() => {
      blase.classList.remove('show');
      walkerEl.style.animationPlayState = 'running';
    }, 4200);
  }

  // --- Türchen rendern ---
  function renderDoors(layout, tueren, today, jahr) {
    const grid = document.getElementById('ak-grid');
    grid.innerHTML = '';
    doorElemente = {};
    globalOpened = getSet(`adventskalender_${jahr}_opened`);
    globalPuenktlich = getSet(`adventskalender_${jahr}_puenktlich`);
    globalJahr = jahr;
    modalState.tueren = tueren;
    modalState.today = today;

    const kerzenEl = document.getElementById('ak-kerzen');
    kerzenEl.innerHTML = '';
    for (let i = 0; i < 24; i++) {
      const k = document.createElement('span');
      k.className = 'ak-kerze';
      kerzenEl.appendChild(k);
    }

    layout.forEach((slot, pos) => {
      const tag = slot.tag;
      const door = document.createElement('button');
      const isLocked = tag > today;
      const isOpened = globalOpened.has(tag) && !isLocked;
      const stateClass = isLocked ? 'locked' : (tag === today ? 'today' : 'unlockable');
      door.className = `ak-door ${slot.size} ${stateClass}` + (isOpened ? ' opened' : '');
      door.setAttribute('role', 'listitem');
      door.setAttribute('aria-label', isLocked ? `Türchen ${tag}, öffnet am ${tag}. Dezember` : `Türchen ${tag}` + (isOpened ? ', geöffnet' : ''));
      doorElemente[tag] = door;

      const daten = getTuerData(tag, tueren);
      const hatBild = isOpened && daten.bild_url;
      const farbe = thumbFarbe(daten.typ);
      const label = thumbLabel(daten.typ);
      const decalSvg = slot.decal >= 0 ? decals[slot.decal] : '';

      door.innerHTML = `
        <span class="door-licht"></span>
        <span class="door-back">
          <span class="door-thumb" style="background:${farbe}">
            ${hatBild ? `<img src="${daten.bild_url}" alt="" loading="lazy">` : label}
          </span>
          <span class="door-back-num">${tag}. Dez</span>
        </span>
        <span class="door-front">
          ${decalSvg}
          <span class="door-num">${tag}</span>
          ${isLocked ? '<span class="door-lock" aria-hidden="true"></span>' : ''}
        </span>
      `;

      door.addEventListener('click', () => {
        if (isLocked) {
          door.classList.add('shake');
          setTimeout(() => door.classList.remove('shake'), 500);
          playLocked();
          showToast(`Türchen öffnet am ${tag}. Dezember`);
          return;
        }
        if (!globalOpened.has(tag)) {
          globalOpened.add(tag);
          saveSet(`adventskalender_${jahr}_opened`, globalOpened);
          registrierePuenktlich(tag);
          door.classList.add('opened');
          if (daten.bild_url) {
            door.querySelector('.door-thumb').innerHTML = `<img src="${daten.bild_url}" alt="" loading="lazy">`;
          }
          updateProgress();
          if (tag === 24) {
            playFinale();
            funkenBurst(door, 16);
            finaleHimmel();
            setTimeout(() => showModal(tag), reducedMotion ? 100 : 1400);
          } else {
            playBell();
            funkenBurst(door);
            setTimeout(() => showModal(tag), reducedMotion ? 100 : 560);
          }
        } else {
          showModal(tag);
        }
      });

      grid.appendChild(door);

      if (reducedMotion) {
        door.style.opacity = '1';
        door.style.transform = 'none';
      } else {
        setTimeout(() => door.classList.add('eingehaengt'), 30 * pos);
      }
    });

    updateProgress();
  }

  // --- Daten laden + initialisieren ---
  async function init() {
    const loadingEl = document.getElementById('ak-loading');
    const errorEl = document.getElementById('ak-error');
    if (!APPS_SCRIPT_URL) {
      loadingEl.classList.add('hidden');
      errorEl.textContent = 'Konfiguration fehlt: APPS_SCRIPT_URL muss im index.html gesetzt werden.';
      errorEl.classList.remove('hidden');
      return;
    }
    try {
      const res = await fetch(APPS_SCRIPT_URL);
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      globalConfig = data.config || {};
      const tueren = data.tueren || [];
      const jahr = Number(globalConfig.jahr) || new Date().getFullYear();
      const titel = globalConfig.titel || `Adventskalender ${jahr}`;
      const testMode = globalConfig.test_mode;
      const today = calcToday(jahr, testMode);

      // Sprüche aus Sheet (optional)
      (data.sprueche || []).forEach(s => {
        const t = Number(s.tag);
        if (t >= 1 && t <= 24 && s.text) sprueche[t] = s.text;
      });

      document.getElementById('ak-title').innerHTML = titel.replace(/(\d{4})/, '<em>$1</em>');
      document.getElementById('ak-meta').textContent = formatToday(today, jahr, testMode);
      document.title = titel;

      setzeMondphase(today);
      if (today >= 20) starteSchnuppenSaison();
      if (today >= 24) document.getElementById('walker2').style.display = '';

      const layout = getLayout(jahr);
      renderDoors(layout, tueren, today, jahr);
      loadingEl.classList.add('hidden');
    } catch (err) {
      loadingEl.classList.add('hidden');
      errorEl.textContent = `Daten konnten nicht geladen werden. ${err.message || ''}`;
      errorEl.classList.remove('hidden');
    }
  }

  // Sound-Toggle
  const soundBtn = document.getElementById('ak-sound-btn');
  soundBtn.onclick = () => {
    soundOn = !soundOn;
    soundBtn.classList.toggle('active', soundOn);
    soundBtn.setAttribute('aria-pressed', String(soundOn));
    soundBtn.textContent = soundOn ? 'Sound: an' : 'Sound: aus';
    if (soundOn) { ensureAudio(); playBell(); }
  };

  // Wanderer klickbar
  document.getElementById('walker').addEventListener('click', walkerKlick);

  // Modal Events
  document.getElementById('ak-modal-x').onclick = closeModal;
  document.getElementById('ak-modal-close').onclick = closeModal;
  document.getElementById('ak-modal-prev').onclick = () => modalNav(-1);
  document.getElementById('ak-modal-next').onclick = () => modalNav(1);
  document.getElementById('ak-modal').addEventListener('click', (e) => {
    if (e.target.id === 'ak-modal') closeModal();
  });
  document.addEventListener('keydown', (e) => {
    const modalOffen = document.getElementById('ak-modal').classList.contains('show');
    if (e.key === 'Escape') closeModal();
    if (modalOffen && e.key === 'ArrowLeft') modalNav(-1);
    if (modalOffen && e.key === 'ArrowRight') modalNav(1);
  });

  // ---------- Geheimbereich: Passwort-Fenster ----------
  function normalisiere(s) {
    return String(s || '').toLowerCase().trim().replace(/[.,!?"'’«»„“]/g, '').replace(/\s+/g, ' ');
  }
  function oeffnePwModal() {
    const m = document.getElementById('ak-pw-modal');
    document.getElementById('ak-pw-fehler').classList.remove('zeig');
    document.getElementById('ak-pw-input').value = '';
    m.classList.add('show');
    m.setAttribute('aria-hidden', 'false');
    setTimeout(() => document.getElementById('ak-pw-input').focus(), 150);
  }
  function schliessePwModal() {
    const m = document.getElementById('ak-pw-modal');
    m.classList.remove('show');
    m.setAttribute('aria-hidden', 'true');
  }
  async function pruefePasswort() {
    const eingabe = normalisiere(document.getElementById('ak-pw-input').value);
    if (!eingabe) return;
    const fehlerEl = document.getElementById('ak-pw-fehler');
    fehlerEl.classList.remove('zeig');
    const knopf = document.getElementById('ak-pw-senden');
    knopf.classList.add('ak-pw-wartet');
    try {
      const res = await fetch(APPS_SCRIPT_URL + (APPS_SCRIPT_URL.includes('?') ? '&' : '?') + 'pw=' + encodeURIComponent(eingabe));
      const data = await res.json();
      knopf.classList.remove('ak-pw-wartet');
      if (data.geheim) {
        schliessePwModal();
        zeigeGeheim(data.geheim);
      } else {
        fehlerEl.classList.add('zeig');
      }
    } catch (e) {
      knopf.classList.remove('ak-pw-wartet');
      fehlerEl.textContent = 'Verbindung fehlgeschlagen — versuch es gleich nochmal.';
      fehlerEl.classList.add('zeig');
    }
  }
  function zeigeGeheim(g) {
    document.getElementById('ak-geheim-titel').textContent = g.titel || 'Willkommen';
    document.getElementById('ak-geheim-text').textContent = g.text || '';
    const rahmen = document.getElementById('ak-geheim-bild-rahmen');
    const bild = document.getElementById('ak-geheim-bild');
    if (g.bild_url) { bild.src = g.bild_url; rahmen.style.display = 'block'; }
    else { rahmen.style.display = 'none'; bild.removeAttribute('src'); }
    const gl = document.getElementById('ak-geheim-link');
    if (g.link) { gl.href = g.link; gl.style.display = 'inline-block'; }
    else { gl.style.display = 'none'; }
    const m = document.getElementById('ak-geheim-modal');
    m.classList.add('show');
    m.setAttribute('aria-hidden', 'false');
    if (typeof playBell === 'function') playBell();
  }
  document.getElementById('ak-pw-x').onclick = schliessePwModal;
  document.getElementById('ak-pw-senden').onclick = pruefePasswort;
  document.getElementById('ak-pw-input').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') pruefePasswort();
  });
  document.getElementById('ak-pw-modal').addEventListener('click', (e) => {
    if (e.target.id === 'ak-pw-modal') schliessePwModal();
  });
  document.getElementById('ak-geheim-x').onclick = () => {
    const m = document.getElementById('ak-geheim-modal');
    m.classList.remove('show'); m.setAttribute('aria-hidden', 'true');
  };
  document.getElementById('ak-geheim-schliessen').onclick = () => {
    const m = document.getElementById('ak-geheim-modal');
    m.classList.remove('show'); m.setAttribute('aria-hidden', 'true');
  };
  document.getElementById('ak-geheim-modal').addEventListener('click', (e) => {
    if (e.target.id === 'ak-geheim-modal') {
      e.currentTarget.classList.remove('show');
      e.currentTarget.setAttribute('aria-hidden', 'true');
    }
  });

  init();
</script>
</body>
</html>
